# Cloudflare Pages 自定义响应头
# 部署后放入 public/_headers 即可生效

# 所有静态资源 — SPA 模式 + CORS
/*
  X-Robots-Tag: noindex
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

# flyfish-viewer 核心 JS — 允许 Craftisle 主站跨域加载
/viewer/assets/*
  Access-Control-Allow-Origin: https://www.craftisle.com
  Access-Control-Allow-Origin: https://craftisle.com
  Access-Control-Allow-Methods: GET, HEAD, OPTIONS
  Access-Control-Allow-Headers: Content-Type, X-Requested-With
  Cache-Control: public, max-age=604800

/viewer/vendor/*
  Access-Control-Allow-Origin: https://www.craftisle.com
  Access-Control-Allow-Origin: https://craftisle.com
  Access-Control-Allow-Methods: GET, HEAD, OPTIONS
  Cache-Control: public, max-age=604800

# index.html — 禁止缓存（确保 postMessage 协议版本即时更新）
/viewer/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  X-Robots-Tag: noindex
